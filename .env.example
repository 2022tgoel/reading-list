# Twitter/X Bearer Token (recommended -- works for all read-only operations)
# Get one at https://developer.x.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your_bearer_token_here

# Twitter/X OAuth 1.0a credentials (optional fallback if no Bearer Token)
# TWITTER_API_KEY=
# TWITTER_API_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_TOKEN_SECRET=

# Optional: override the database location (defaults to ./papers.db)
# DATABASE_URL=sqlite:///path/to/papers.db
